<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="NTE_Fishing_Bot.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:NTE_Fishing_Bot" x:Name="MainWindows" Title="NTE Fisherman" Height="800" Width="900">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources/StylingDictionary.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </FrameworkElement.Resources>

  <Grid Name="Main_Window">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- SIDEBAR -->
    <Border Name="SideMenuBorder" Grid.Column="0" Width="200" BorderThickness="0,0,1,0">
      <DockPanel>

        <!-- Ko-fi + version pinned to bottom -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,4">
          <Button Name="KofiBtn" Height="42" HorizontalAlignment="Stretch"
                  Margin="6,2,6,2" Click="KofiBtn_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x2665;" FontSize="15" Width="20" TextAlignment="Center"
                         Foreground="#FF5E5B" VerticalAlignment="Center" />
              <TextBlock Name="SideKofiLabel" Text="Support Ko-fi" Margin="9,0,0,0"
                         VerticalAlignment="Center" FontSize="12" Foreground="#FF5E5B" />
            </StackPanel>
          </Button>
          <TextBlock Name="VersionLabel" Text="v2.5" FontSize="11" HorizontalAlignment="Left"
                     Margin="10,3,0,4" Foreground="#FF666666" />
        </StackPanel>

        <StackPanel>
          <!-- Brand header -->
          <StackPanel Name="BrandHeader" Orientation="Horizontal" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Margin="0,14,0,8">
            <TextBlock Text="&#x1F3A3;" FontSize="30" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="NTE Fisherman" FontSize="17" FontWeight="Bold" VerticalAlignment="Center" />
          </StackPanel>
          <Separator Name="BrandSeparator" Margin="10,0,10,4" />

          <Button Name="HamburgerBtn" Height="38" HorizontalAlignment="Stretch"
                  Style="{StaticResource btnRoundDark}" Margin="6,4,6,4"
                  Click="HamburgerBtn_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x2630;" FontSize="16" VerticalAlignment="Center" />
              <TextBlock Name="CloseMenuLabel" Text="Close Menu" Margin="9,0,0,0"
                         VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" />
            </StackPanel>
          </Button>

          <Separator Name="SideMenuSeparator" Margin="10,6,10,6" />

          <Button Name="SettingBtn" Height="42" HorizontalAlignment="Stretch"
                  Margin="6,2,6,2" Click="SettingBtn_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x2699;" FontSize="16" Width="20" TextAlignment="Center" VerticalAlignment="Center" />
              <TextBlock Name="SideSettingLabel" Text="Settings" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="12" />
            </StackPanel>
          </Button>

          <Button Name="ThemeModeBtn" Height="42" HorizontalAlignment="Stretch"
                  Margin="6,2,6,2" Click="ThemeModeBtn_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x25D1;" FontSize="16" Width="20" TextAlignment="Center" VerticalAlignment="Center" />
              <TextBlock Name="SideThemeLabel" Text="Dark Mode" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="12" />
            </StackPanel>
          </Button>

          <Button Name="AlwaysOnTopBtn" Height="42" HorizontalAlignment="Stretch"
                  Margin="6,2,6,2" Click="AlwaysOnTopBtn_Click" ToolTip="Always On Top">
            <StackPanel Orientation="Horizontal">
              <TextBlock Name="AlwaysOnTopIcon" Text="&#x1F4CC;" FontSize="15" Width="20"
                         TextAlignment="Center" VerticalAlignment="Center" />
              <TextBlock Name="SideAlwaysOnTopLabel" Text="Stay on Top" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="12" />
            </StackPanel>
          </Button>

          <Button Name="BackgroundInputBtn" Height="42" HorizontalAlignment="Stretch"
                  Margin="6,2,6,2" Click="BackgroundInputBtn_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Name="BackgroundInputIcon" Text="&#x2328;" FontSize="15" Width="20" TextAlignment="Center" VerticalAlignment="Center" />
              <TextBlock Name="BackgroundInputLabel" Text="Background Inputs: Off" Margin="9,0,0,0"
                         VerticalAlignment="Center" FontSize="10" TextWrapping="Wrap" MaxWidth="108" />
            </StackPanel>
          </Button>

          <Separator Name="SideMenuCategorySeparator" Margin="10,6,10,6" />

          <Button Name="FaqBtn" Height="42" HorizontalAlignment="Stretch"
                  Margin="6,2,6,2" Click="FaqBtn_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="?" FontSize="18" FontWeight="Bold" Width="20"
                         TextAlignment="Center" VerticalAlignment="Center" />
              <TextBlock Name="SideFaqLabel" Text="FAQ" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="12" />
            </StackPanel>
          </Button>

          <Button Name="LogBtn" Height="42" HorizontalAlignment="Stretch"
                  Margin="6,2,6,2" Click="LogBtn_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x1F4CB;" FontSize="14" Width="20"
                         TextAlignment="Center" VerticalAlignment="Center" />
              <TextBlock Name="SideLogLabel" Text="Debug Log" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="12" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- MAIN CONTENT -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- TOP BAR (admin warning only) -->
      <Border Name="AdminWarningBanner" Grid.Row="0" Background="#FFFFC107" CornerRadius="4"
              Padding="6,5" Margin="10,8,10,4" Visibility="Collapsed">
        <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="10" Foreground="#FF000000">
          &#x26A0; Not running as Administrator. Some inputs may not work. Please restart as Admin.
        </TextBlock>
      </Border>

      <!-- MAIN AREA -->
      <Grid Grid.Row="1" Margin="10,8,10,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="278" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Setup sections -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,8,0">
          <StackPanel>

            <!-- Section 1: Middle Bar Setup -->
            <GroupBox Name="MiddleBarCard" BorderThickness="4" Margin="0,0,0,8" Padding="10,8,10,10">
              <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                  <Border Background="#1A4874" CornerRadius="10" Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center">
                    <TextBlock Text="1" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#35A7F1" />
                  </Border>
                  <TextBlock Name="MiddleBarSectionTitle" Text="Middle Bar Setup" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
              </GroupBox.Header>
              <Grid Margin="0,4,0,0">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <Button Name="UpperLeftBtn" Grid.Row="0" Grid.Column="0" Height="50"
                          Style="{StaticResource btnRoundDark}" BorderThickness="2"
                          Margin="0,0,3,0" Click="UpperLeftBtn_Click">
                    <TextBlock Name="UpperLeftLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="12">
                      <Run Text="Upper" /><LineBreak /><Run Text="Left" />
                    </TextBlock>
                  </Button>
                  <Button Name="MiddleBarColorBtn" Grid.Row="0" Grid.Column="1" Height="50"
                          Style="{StaticResource btnRoundDark}" BorderThickness="2"
                          Margin="3,0,3,0" Click="MiddleBarColorBtn_Click">
                    <TextBlock Name="MiddleBarColorLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="12">Middle Bar</TextBlock>
                  </Button>
                  <Button Name="LowerRightBtn" Grid.Row="0" Grid.Column="2" Height="50"
                          Style="{StaticResource btnRoundDark}" BorderThickness="2"
                          Margin="3,0,0,0" Click="LowerRightBtn_Click">
                    <TextBlock Name="LowerRightLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="12">
                      <Run Text="Lower" /><LineBreak /><Run Text="Right" />
                    </TextBlock>
                  </Button>

                  <Border Grid.Row="1" Grid.Column="0" Name="UpperLeftCoordBadge" CornerRadius="5" BorderThickness="1" Padding="4,3" Margin="0,5,3,0">
                    <TextBlock Name="UpperLeftCoords" Text="X: ?  Y: ?" FontSize="9" TextAlignment="Center" Foreground="#7FA8C8" />
                  </Border>
                  <Border Grid.Row="1" Grid.Column="2" Name="LowerRightCoordBadge" CornerRadius="5" BorderThickness="1" Padding="4,3" Margin="3,5,0,0">
                    <TextBlock Name="LowerRightCoords" Text="X: ?  Y: ?" FontSize="9" TextAlignment="Center" Foreground="#7FA8C8" />
                  </Border>
                </Grid>

                <Button Name="CursorColorBtn" Grid.Row="1" Height="42" HorizontalAlignment="Center"
                        Width="150" Style="{StaticResource btnRoundDark}" BorderThickness="2"
                        Margin="0,10,0,0" Click="CursorColorBtn_Click">
                  <TextBlock Name="CursorColorLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="12">Cursor Color</TextBlock>
                </Button>

                <Button Name="ResetPositionsBtn" Grid.Row="2" Height="30" HorizontalAlignment="Right"
                        Width="150" Style="{StaticResource btnRoundDark}"
                        Margin="0,8,0,0" Click="ResetPositionsBtn_Click">
                  <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="11">&#x21BA; Reset Positions</TextBlock>
                </Button>
              </Grid>
            </GroupBox>

            <!-- Section 2: Detection Setup -->
            <GroupBox Name="DetectionCard" BorderThickness="4" Margin="0,0,0,8" Padding="10,8,10,10">
              <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                  <Border Background="#1A4874" CornerRadius="10" Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center">
                    <TextBlock Text="2" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#35A7F1" />
                  </Border>
                  <TextBlock Name="DetectionSectionTitle" Text="Detection Setup" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
              </GroupBox.Header>
              <Grid Margin="0,4,0,0">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <Button Name="CastBtnBtn" Grid.Row="0" Grid.Column="0" Height="50"
                          Style="{StaticResource btnRoundDark}" BorderThickness="2"
                          Margin="0,0,3,0" Click="CastBtnBtn_Click">
                    <TextBlock Name="CastBtnLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="12">Cast Button<LineBreak />Detection</TextBlock>
                  </Button>
                  <Button Name="XpBarColorBtn" Grid.Row="0" Grid.Column="1" Height="50"
                          Style="{StaticResource btnRoundDark}" BorderThickness="2"
                          Margin="3,0,0,0" Click="XpBarColorBtn_Click">
                    <TextBlock Name="XpBarColorLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="12">XP Bar<LineBreak />Detect</TextBlock>
                  </Button>

                  <Border Grid.Row="1" Grid.Column="0" Name="CastBtnCoordBadge" CornerRadius="5" BorderThickness="1" Padding="4,3" Margin="0,5,3,0">
                    <TextBlock Name="CastBtnCoords" Text="X: ?  Y: ?" FontSize="9" TextAlignment="Center" Foreground="#7FA8C8" />
                  </Border>
                  <Border Grid.Row="1" Grid.Column="1" Name="XpBarCoordBadge" CornerRadius="5" BorderThickness="1" Padding="4,3" Margin="3,5,0,0">
                    <TextBlock Name="XpBarCoords" Text="X: ?  Y: ?" FontSize="9" TextAlignment="Center" Foreground="#7FA8C8" />
                  </Border>

                  <Rectangle Name="CastBtnIndicator" Grid.Row="2" Grid.Column="0" Height="6" RadiusX="3" RadiusY="3"
                             HorizontalAlignment="Center" Width="40" Margin="0,6,3,0" Fill="#FF444444" />
                  <Rectangle Name="XpBarIndicator" Grid.Row="2" Grid.Column="1" Height="6" RadiusX="3" RadiusY="3"
                             HorizontalAlignment="Center" Width="40" Margin="3,6,0,0" Fill="#FF444444" />
                </Grid>

                <Button Name="DailyRewardBtn" Grid.Row="1" Height="50" HorizontalAlignment="Stretch"
                        Style="{StaticResource btnRoundDark}" BorderThickness="2"
                        Margin="0,8,0,0" Click="DailyRewardBtn_Click">
                  <TextBlock Name="DailyRewardLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="12">Daily Reward<LineBreak />Popup Detect</TextBlock>
                </Button>

                <Border Grid.Row="2" Name="DailyRewardCoordBadge" CornerRadius="5" BorderThickness="1" Padding="4,3" Margin="0,5,0,0">
                  <TextBlock Name="DailyRewardCoords" Text="X: ?  Y: ?" FontSize="9" TextAlignment="Center" Foreground="#7FA8C8" />
                </Border>

                <Rectangle Name="DailyRewardIndicator" Grid.Row="3" Height="6" RadiusX="3" RadiusY="3"
                           HorizontalAlignment="Center" Width="40" Margin="0,6,0,0" Fill="#FF444444" />

                <TextBlock Grid.Row="4" FontSize="9" Foreground="#7FA8C8" Margin="0,4,0,0"
                           TextWrapping="Wrap" TextAlignment="Center">
                  &#x26A0; Daily Reward is only auto-configured by Auto-Scale. Set it manually if needed.
                </TextBlock>
              </Grid>
            </GroupBox>

            <!-- Section 3: Stamina Setup -->
            <GroupBox Name="StaminaCard" BorderThickness="4" Margin="0,0,0,8" Padding="10,8,10,10">
              <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                  <Border Background="#1A4874" CornerRadius="10" Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center">
                    <TextBlock Text="3" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#35A7F1" />
                  </Border>
                  <TextBlock Name="StaminaSectionTitle" Text="Stamina Setup" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
              </GroupBox.Header>
              <Grid Margin="0,4,0,0">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <Button Name="FishStaminaColorBtn" Grid.Row="0" Grid.Column="0" Height="50"
                          Style="{StaticResource btnRoundDark}" BorderThickness="2"
                          Margin="0,0,3,0" Click="FishStaminaColorBtn_Click">
                    <TextBlock Name="FishStaminaColorLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="12">Fish</TextBlock>
                  </Button>
                  <Button Name="PlayerStaminaColorBtn" Grid.Row="0" Grid.Column="1" Height="50"
                          Style="{StaticResource btnRoundDark}" BorderThickness="2"
                          Margin="3,0,0,0" Click="PlayerStaminaColorBtn_Click">
                    <TextBlock Name="PlayerStaminaColorLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="12">Player</TextBlock>
                  </Button>

                  <Border Grid.Row="1" Grid.Column="0" Name="FishStaminaCoordBadge" CornerRadius="5" BorderThickness="1" Padding="4,3" Margin="0,5,3,0">
                    <TextBlock Name="FishStaminaCoords" Text="X: ?  Y: ?" FontSize="9" TextAlignment="Center" Foreground="#7FA8C8" />
                  </Border>
                  <Border Grid.Row="1" Grid.Column="1" Name="PlayerStaminaCoordBadge" CornerRadius="5" BorderThickness="1" Padding="4,3" Margin="3,5,0,0">
                    <TextBlock Name="PlayerStaminaCoords" Text="X: ?  Y: ?" FontSize="9" TextAlignment="Center" Foreground="#7FA8C8" />
                  </Border>

                  <Rectangle Name="FishStaminaIndicator" Grid.Row="2" Grid.Column="0" Height="6" RadiusX="3" RadiusY="3"
                             HorizontalAlignment="Center" Width="40" Margin="0,6,3,0" Fill="#FF444444" />
                  <Rectangle Name="PlayerStaminaIndicator" Grid.Row="2" Grid.Column="1" Height="6" RadiusX="3" RadiusY="3"
                             HorizontalAlignment="Center" Width="40" Margin="3,6,0,0" Fill="#FF444444" />
                </Grid>
              </Grid>
            </GroupBox>

          </StackPanel>
        </ScrollViewer>

        <!-- RIGHT PANEL -->
        <Grid Grid.Column="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Chibi + Setup Status -->
          <GroupBox Grid.Row="0" Name="StatusPanelCard" BorderThickness="4" Header="Setup Status" Padding="12,8,12,10" Margin="0,0,0,8">
            <StackPanel>
              <Image Source="/img/chibi.png" Height="145" HorizontalAlignment="Center"
                     VerticalAlignment="Center" Stretch="Uniform" Margin="0,0,0,10" />

              <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Name="StatusMiddleBarIcon" Text="&#x25CB;" Grid.Column="0" FontSize="13"
                           Margin="0,0,8,0" Foreground="#7FA8C8" VerticalAlignment="Center" />
                <TextBlock Name="StatusMiddleBarText" Grid.Column="1" Text="Middle Bar" FontSize="11" VerticalAlignment="Center" />
              </Grid>

              <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Name="StatusDetectionIcon" Text="&#x25CB;" Grid.Column="0" FontSize="13"
                           Margin="0,0,8,0" Foreground="#7FA8C8" VerticalAlignment="Center" />
                <TextBlock Name="StatusDetectionText" Grid.Column="1" Text="Detection" FontSize="11" VerticalAlignment="Center" />
              </Grid>

              <Grid Margin="0,2,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Name="StatusStaminaIcon" Text="&#x25CB;" Grid.Column="0" FontSize="13"
                           Margin="0,0,8,0" Foreground="#7FA8C8" VerticalAlignment="Center" />
                <TextBlock Name="StatusStaminaText" Grid.Column="1" Text="Stamina" FontSize="11" VerticalAlignment="Center" />
              </Grid>

              <TextBlock Name="ChibiHintLabel" TextWrapping="Wrap" FontSize="9" FontStyle="Italic"
                         Foreground="#7FA8C8" TextAlignment="Center">
                Check the FAQ if you need help getting started!
              </TextBlock>
            </StackPanel>
          </GroupBox>

          <!-- Output + Controls -->
          <StackPanel Grid.Row="1">

            <!-- Status card -->
            <GroupBox Name="OutputCard" BorderThickness="4" Header="Output" Padding="10,8,10,10" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <Label Name="StatusLabel" Content="Status: Idle" FontSize="13" FontWeight="SemiBold"
                         Padding="0" Margin="0,0,0,2" />
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Name="FishCaughtLabel" Text="&#x1F3A3;  Caught: 0" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button Name="FishCaughtResetBtn" Content="&#x21BA;" ToolTip="Reset catch count"
                            Width="22" Height="22" FontSize="11" Padding="0"
                            VerticalAlignment="Center" Click="FishCaughtResetBtn_Click" />
                  </StackPanel>
                  <TextBlock Name="SessionTimerLabel" Text="Session: --:--" FontSize="11" />
                </StackPanel>
                <!-- Hidden debug labels (required by FishingThread) -->
                <StackPanel Grid.Column="1" Visibility="Collapsed">
                  <Label Name="cursor" Content="" FontSize="9" Padding="0,1" />
                  <Label Name="bar" Content="" FontSize="9" Padding="2,1" />
                </StackPanel>
              </Grid>
            </GroupBox>

            <!-- Middle bar mask visual -->
            <GroupBox Name="BarMaskCard" BorderThickness="4" Header="Bar Preview" Padding="6,4,6,6" Margin="0,0,0,8">
              <StackPanel>
                <Image Name="middleBarImage" Height="20" HorizontalAlignment="Stretch" />
                <Image Name="cursorImage" Height="20" HorizontalAlignment="Stretch" Margin="0,4,0,0" />
              </StackPanel>
            </GroupBox>

            <!-- Keybind cards -->
            <GroupBox Name="KeybindCard" BorderThickness="4" Header="Key Inputs" Padding="6,4,6,6" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="44" Height="44" HorizontalAlignment="Center">
                  <Rectangle Name="LeftBox" Stroke="#FF000000" RadiusX="10" RadiusY="10" Fill="#00000000" />
                  <TextBlock Name="MoveLeftLabel" HorizontalAlignment="Center" Text="A"
                             VerticalAlignment="Center" FontSize="20" />
                </Grid>
                <Grid Grid.Column="1" Width="44" Height="44" HorizontalAlignment="Center">
                  <Rectangle Name="RightBox" Stroke="#FF000000" RadiusX="10" RadiusY="10" Fill="#00000000" />
                  <TextBlock Name="MoveRightLabel" HorizontalAlignment="Center" Text="D"
                             VerticalAlignment="Center" FontSize="20" />
                </Grid>
                <Grid Grid.Column="2" Width="52" Height="44" HorizontalAlignment="Center">
                  <Rectangle Name="EscBox" Stroke="#FF000000" RadiusX="10" RadiusY="10" Fill="#00000000" />
                  <TextBlock Name="EscBoxLabel" HorizontalAlignment="Center" Text="ESC"
                             VerticalAlignment="Center" FontSize="13" />
                </Grid>
                <Grid Grid.Column="3" Width="44" Height="44" HorizontalAlignment="Center">
                  <Rectangle Name="FBox" Stroke="#FF000000" RadiusX="10" RadiusY="10" Fill="#00000000" />
                  <TextBlock Name="FBoxLabel" HorizontalAlignment="Center" Text="F"
                             VerticalAlignment="Center" FontSize="20" />
                </Grid>
                <Grid Grid.Column="4" Width="44" Height="44" HorizontalAlignment="Center">
                  <Ellipse Name="CastReadyRing" Stroke="#FF444444" StrokeThickness="2" />
                  <Image Name="castReadyImage" Width="40" Height="40" Stretch="Uniform"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image.Clip>
                      <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20" />
                    </Image.Clip>
                  </Image>
                </Grid>
              </Grid>
            </GroupBox>

            <!-- Bait counter -->
            <Border Name="BaitCounterBorder" CornerRadius="8" BorderThickness="1.5" Margin="0,0,0,8" Padding="10,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                  <TextBlock Text="BAIT REMAINING" FontSize="7" FontWeight="Bold"
                             Foreground="#FF888888" Margin="0,0,0,2" />
                  <TextBlock Name="BaitRemainingLabel" Text="Unlimited" FontSize="16"
                             FontWeight="Bold" Foreground="#FF888888" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                  <TextBlock Text="Bait count" FontSize="7" Foreground="#FF888888"
                             TextAlignment="Center" Margin="0,0,0,2" />
                  <TextBox Name="BaitCountTextBox" Width="72" FontSize="12" TextAlignment="Center"
                           MaxLength="5" Padding="3,2"
                           PreviewTextInput="SpPositiveNumbersOnlyValidation"
                           TextChanged="BaitCountTextBox_TextChanged" />
                  <TextBlock Text="blank = unlimited" FontSize="7"
                             Foreground="#FF888888" TextAlignment="Center" Margin="0,2,0,0" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Start Fishing button -->
            <Button Name="StartBtn" Height="58" HorizontalAlignment="Stretch"
                    Style="{StaticResource btnRoundDark}" Click="StartBtn_Click" Margin="0,0,0,6">
              <TextBlock Name="StartLabel" TextWrapping="Wrap" TextAlignment="Center"
                         FontSize="17" FontWeight="Bold">Start&#x0a;Fishing</TextBlock>
            </Button>

            <!-- Auto-Scale -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Rectangle Name="PreConfigIndicator" Height="7" Width="7" RadiusX="3" RadiusY="3"
                         Margin="0,0,5,0" VerticalAlignment="Center" Fill="#FF444444" />
              <Button Name="PreConfigBtn" Style="{StaticResource btnRoundDark}" Height="24" Width="140"
                      Click="PreConfigBtn_Click">
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="9">1280x720  Auto-Scale</TextBlock>
              </Button>
            </StackPanel>

          </StackPanel>
        </Grid>
      </Grid>
    </Grid>

    <!-- Settings Page Overlay -->
    <Grid Name="SettingsPage" Grid.Column="1" Visibility="Collapsed" Panel.ZIndex="11">
      <Border Name="SettingsPageBorder" Margin="5,5,5,5" CornerRadius="8" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="14,10,10,8">
            <TextBlock Name="SettingsTitleLabel" Text="Settings" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Name="SpCloseBtn" Content="&#x2715;" HorizontalAlignment="Right"
                    Width="28" Height="28" Style="{StaticResource btnRoundDark}"
                    Click="SpCloseBtn_Click" />
          </Grid>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="10,0,10,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <GroupBox Name="SpButtonsGBox" Header="Button Setup" Grid.Column="0" Margin="0,4,6,4" VerticalAlignment="Top">
                <StackPanel Margin="4">
                  <StackPanel Height="65" Orientation="Horizontal">
                    <Button Name="SpMoveLeftBtn" Height="50" Width="70" Style="{StaticResource btnRoundDark}" BorderThickness="2" Margin="8,0,0,0" Click="SpMoveLeftBtn_Click">
                      <TextBlock Name="SpMoveLeftLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="22" Text="A" />
                    </Button>
                    <Label Name="SpMoveLeftDescription" Content="Move Left&#xD;&#xA;(Default: A)" VerticalAlignment="Center" Width="118" VerticalContentAlignment="Center" Margin="8,0,0,0" />
                  </StackPanel>
                  <StackPanel Height="65" Orientation="Horizontal">
                    <Button Name="SpMoveRightBtn" Height="50" Width="70" Style="{StaticResource btnRoundDark}" BorderThickness="2" Margin="8,0,0,0" Click="SpMoveRightBtn_Click">
                      <TextBlock Name="SpMoveRightLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="22" Text="D" />
                    </Button>
                    <Label Name="SpMoveRightDescription" Content="Move Right&#xD;&#xA;(Default: D)" VerticalAlignment="Center" Width="118" VerticalContentAlignment="Center" Margin="8,0,0,0" />
                  </StackPanel>
                  <StackPanel Height="65" Orientation="Horizontal">
                    <Button Name="SpReelInBtn" Height="50" Width="70" Style="{StaticResource btnRoundDark}" BorderThickness="2" Margin="8,0,0,0" Click="SpReelInBtn_Click">
                      <TextBlock Name="SpReelInLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="22" Text="F" />
                    </Button>
                    <Label Name="SpReelInDescription" Content="Reel-In&#xD;&#xA;(Default: F)" VerticalAlignment="Center" Width="118" VerticalContentAlignment="Center" Margin="8,0,0,0" />
                  </StackPanel>
                  <StackPanel Height="65" Orientation="Horizontal">
                    <Button Name="SpDismissBtn" Height="50" Width="70" Style="{StaticResource btnRoundDark}" BorderThickness="2" Margin="8,0,0,0" Click="SpDismissBtn_Click">
                      <TextBlock Name="SpDismissLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="18" Text="ESC" />
                    </Button>
                    <Label Name="SpDismissDescription" Content="Dismiss&#xD;&#xA;(Default: ESC)" VerticalAlignment="Center" Width="118" VerticalContentAlignment="Center" Margin="8,0,0,0" />
                  </StackPanel>
                </StackPanel>
              </GroupBox>
              <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <GroupBox Name="SpDelayGBox" Header="Delays (ms)" Grid.Row="0" Margin="0,4,0,6">
                  <Grid Margin="8,4,8,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Label Name="SpRestartDelayLabel" Content="Restart Delay" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" FontSize="11" Padding="2" />
                    <TextBox Name="SpRestartDelayTextBox" Grid.Row="1" Grid.Column="0" Width="80" HorizontalAlignment="Center" FontSize="14" TextAlignment="Center" Margin="0,0,0,8" TextChanged="SpDelayTextBox_TextChanged" PreviewTextInput="SpPositiveNumbersOnlyValidation" />
                    <Label Name="SpLagCompensationLabel" Content="Lag Comp Delay" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" FontSize="11" Padding="2" />
                    <TextBox Name="SpLagCompensationDelayTextBox" Grid.Row="1" Grid.Column="1" Width="80" HorizontalAlignment="Center" FontSize="14" TextAlignment="Center" Margin="0,0,0,8" TextChanged="SpDelayTextBox_TextChanged" PreviewTextInput="SpPositiveNumbersOnlyValidation" />
                    <Label Name="SpDimissDelayLabel" Content="Dismiss Delay" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" FontSize="11" Padding="2" />
                    <TextBox Name="SpDimissDelayTextBox" Grid.Row="3" Grid.Column="0" Width="80" HorizontalAlignment="Center" FontSize="14" TextAlignment="Center" Margin="0,0,0,8" TextChanged="SpDelayTextBox_TextChanged" PreviewTextInput="SpPositiveNumbersOnlyValidation" />
                    <Label Name="SpFishCaptureLabel" Content="Fish Capture Delay" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" FontSize="11" Padding="2" />
                    <TextBox Name="SpFishCaptureDelayTextBox" Grid.Row="3" Grid.Column="1" Width="80" HorizontalAlignment="Center" FontSize="14" TextAlignment="Center" Margin="0,0,0,8" TextChanged="SpDelayTextBox_TextChanged" PreviewTextInput="SpPositiveNumbersOnlyValidation" />
                    <Label Name="SpPostCatchDelayLabel" Content="After Catch" Grid.Row="4" Grid.Column="0" HorizontalAlignment="Center" FontSize="11" Padding="2" />
                    <TextBox Name="SpPostCatchDelayTextBox" Grid.Row="5" Grid.Column="0" Width="80" HorizontalAlignment="Center" FontSize="14" TextAlignment="Center" Margin="0,0,0,8" TextChanged="SpDelayTextBox_TextChanged" PreviewTextInput="SpPositiveNumbersOnlyValidation" />
                    <Label Name="SpAfterClickDelayLabel" Content="After Esc" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Center" FontSize="11" Padding="2" />
                    <TextBox Name="SpAfterClickDelayTextBox" Grid.Row="5" Grid.Column="1" Width="80" HorizontalAlignment="Center" FontSize="14" TextAlignment="Center" Margin="0,0,0,8" TextChanged="SpDelayTextBox_TextChanged" PreviewTextInput="SpPositiveNumbersOnlyValidation" />
                    <Label Name="SpGPULabel" Content="GPU Selection" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" FontSize="11" Padding="2" />
                    <ComboBox Name="SpGPUList" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" Margin="0,0,0,4" SelectionChanged="SpGPUList_SelectionChanged" />
                  </Grid>
                </GroupBox>
                <GroupBox Name="SpDiscordGBox" Header="Discord Integration (WIP)" Grid.Row="1" Margin="0,0,0,6">
                  <StackPanel Margin="8,4,8,4">
                    <Label Name="SpDiscordUserIdLabel" Content="Discord User Id" FontSize="11" Padding="2" />
                    <TextBox Name="SpDiscordUserIdTextBox" HorizontalAlignment="Stretch" FontSize="13" TextAlignment="Left" Margin="0,0,0,6" TextChanged="SpDelayTextBox_TextChanged" PreviewTextInput="SpPositiveNumbersOnlyValidation" />
                    <Label Name="SpDiscordWebHookLabel" Content="Discord Webhook URL" FontSize="11" Padding="2" />
                    <TextBox Name="SpDiscordWebHookTextBox" HorizontalAlignment="Stretch" FontSize="13" TextAlignment="Left" TextWrapping="Wrap" AcceptsReturn="True" Height="42" TextChanged="SpDelayTextBox_TextChanged" />
                  </StackPanel>
                </GroupBox>
                <Button Name="SpResetBtn" Grid.Row="2" HorizontalAlignment="Right" Height="44" Width="140"
                        Style="{StaticResource btnRoundDark}" BorderThickness="2" Margin="0,0,0,4"
                        Click="SpResetBtn_Click">
                  <TextBlock Name="SpResetLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Text="Reset All To Default" />
                </Button>
              </Grid>
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- FAQ Overlay Page -->
    <Grid Name="FaqPage" Grid.Column="1" Visibility="Collapsed" Panel.ZIndex="10">
      <Border Name="FaqPageBorder" Margin="5,5,5,5" CornerRadius="8" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="14,10,10,8">
            <TextBlock Name="FaqTitleLabel" Text="FAQ" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Name="FaqCloseBtn" Content="&#x2715;" HorizontalAlignment="Right"
                    Width="28" Height="28" Style="{StaticResource btnRoundDark}"
                    Click="FaqCloseBtn_Click" />
          </Grid>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="FaqContentPanel" Margin="14,4,14,14">
              <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,6">
                <Run FontWeight="Bold">NTE Fisherman</Run>
                <Run> is an automated fishing bot for NTE that handles casting, reeling, and recasting. You don't have to watch the screen and click manually. It requires some setup, but after the first working one it doesn't really require another setup.</Run>
              </TextBlock>
              <Border Name="FaqQuoteBorder" BorderThickness="3,0,0,0" Margin="0,0,0,14" Padding="10,6">
                <TextBlock TextWrapping="Wrap" FontSize="11" FontStyle="Italic">Follow the video/picture step by step, you won't have issues.</TextBlock>
              </Border>
              <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="Bold" Margin="0,0,0,4">Recommended: Play with Full Focus</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,14">Use the bot while the game is your active window. This is the most stable and reliable mode. The bot will handle all inputs cleanly and fishing will work as expected.</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="Bold" Margin="0,0,0,4">Background Inputs</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,14">Background Inputs now works properly and lets the bot send inputs while you're focused on another window. That said, it can still occasionally bug out, so it's best used when you're keeping an eye on the game on the side. If you plan to go fully AFK, keep the game focused for the most reliable experience.</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="Bold" Margin="0,0,0,4">Starting Out at Level 1 Fishing</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,8">If you're just starting, watch the bot for at least the first hour. You'll need to manually sell your fish and use the money to buy more bait to keep the cycle going. The overnight/AFK farm only becomes reliable once you have around 1,000+ bait stockpiled.</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" Margin="10,0,0,2">• 99 Stacks of Basic Bait = 495 Shell</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" Margin="10,0,0,2">• Avg starting fish is 10 to 20 Shell</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" Margin="10,0,0,14">
                <Run>• You need about </Run><Run FontWeight="Bold">5,445 Shell total</Run><Run> for 1k bait (more the better)</Run>
              </TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="Bold" Margin="0,0,0,4">Customizing Delays</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,6">Only delays I would recommend to touch are:</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="Courier New" Margin="10,0,0,2">Dismiss Delay (default: 4000)  →  2000</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="Courier New" Margin="10,0,0,2">After Catch (default: 1000)    →  1000</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="Courier New" Margin="10,0,0,0">After Esc   (default: 1000)    →  same</TextBlock>
            </StackPanel>
          </ScrollViewer>
          <Grid Grid.Row="2" MinHeight="155">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Button Name="FaqWelcomeBtn" Width="155" Height="115" Margin="0,0,14,0"
                      Style="{StaticResource btnSquareDark}" Click="FaqWelcomeBtn_Click">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="&#x1F44B;" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8" />
                  <TextBlock Text="Welcome&#x0a;Screen" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
              </Button>
              <Button Name="FaqVideoBtn" Width="155" Height="115" Margin="0,0,14,0"
                      Style="{StaticResource btnSquareDark}" Click="FaqVideoBtn_Click">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="&#x25B6;" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8" />
                  <TextBlock Text="Video Setup&#x0a;Guide" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
              </Button>
              <Button Name="FaqGithubBtn" Width="155" Height="115"
                      Style="{StaticResource btnSquareDark}" Click="FaqGithubBtn_Click">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="&lt;/&gt;" FontSize="32" FontFamily="Courier New" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8" />
                  <TextBlock Text="GitHub" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <!-- Debug Log Overlay Page -->
    <Grid Name="LogPage" Grid.Column="1" Visibility="Collapsed" Panel.ZIndex="9">
      <Border Name="LogPageBorder" Margin="5,5,5,5" CornerRadius="8" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="14,10,10,8">
            <TextBlock Name="LogTitleLabel" Text="Debug Log" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Button Name="LogExportBtn" Content="Export" Width="60" Height="28"
                      Style="{StaticResource btnRoundDark}" Margin="0,0,6,0" Click="LogExportBtn_Click" />
              <Button Name="LogClearBtn" Content="Clear" Width="55" Height="28"
                      Style="{StaticResource btnRoundDark}" Margin="0,0,6,0" Click="LogClearBtn_Click" />
              <Button Name="LogCloseBtn" Content="&#x2715;" Width="28" Height="28"
                      Style="{StaticResource btnRoundDark}" Click="LogCloseBtn_Click" />
            </StackPanel>
          </Grid>
          <ListBox Name="LogListBox" Grid.Row="1" Margin="10,0,10,6"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   BorderThickness="1" FontFamily="Consolas" FontSize="11" />
          <TextBlock Name="LogCountLabel" Grid.Row="2" Margin="14,0,14,8" FontSize="10" Text="0 entries" />
        </Grid>
      </Border>
    </Grid>

    <!-- Welcome / First-Run Page -->
    <Grid Name="WelcomePage" Grid.Column="1" Visibility="Collapsed" Panel.ZIndex="12">
      <Border Name="WelcomePageBorder" Margin="5,5,5,5" CornerRadius="8" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="14,10,10,8">
            <TextBlock Name="WelcomeTitleLabel" Text="&#x1F44B;  Welcome to NTE Fisherman"
                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Name="WelcomeCloseBtn" Content="&#x2715;" HorizontalAlignment="Right"
                    Width="28" Height="28" Style="{StaticResource btnRoundDark}"
                    Click="WelcomeCloseBtn_Click" />
          </Grid>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="WelcomeContentPanel" Margin="14,4,14,10">
              <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="Bold" Margin="0,0,0,6">How the bot works</TextBlock>
              <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,16">NTE Fisherman reads your screen in real-time to detect the fishing bar position, cursor location, stamina levels, and cast confirmation. It sends keyboard inputs to reel in and recast automatically. No game files are modified.</TextBlock>
              <Border Name="WelcomeFocusWarnBorder" BorderThickness="1" CornerRadius="4"
                      BorderBrush="#FFDC3545" Padding="10,8" Margin="0,0,0,16">
                <StackPanel>
                  <TextBlock Text="&#x26A0;  Heads Up" FontSize="12" FontWeight="Bold"
                             Foreground="#FFDC3545" Margin="0,0,0,5" />
                  <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#FFDC3545">Without Background Inputs, the game must stay fully focused. Background Inputs works for multitasking but can occasionally bug out. For fully AFK sessions, keep the game focused.</TextBlock>
                </StackPanel>
              </Border>
              <Border Name="WelcomeFaqBorder" BorderThickness="3,0,0,0" Padding="10,6" Margin="0,0,0,6">
                <TextBlock TextWrapping="Wrap" FontSize="12" FontStyle="Italic">It is strongly recommended to read the FAQ before starting setup. It covers the full setup process, delay tuning, bait management, and common issues.</TextBlock>
              </Border>
            </StackPanel>
          </ScrollViewer>
          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="14,6,14,12">
            <Button Name="WelcomeFaqBtn" Content="Open FAQ" Width="90" Height="32"
                    Style="{StaticResource btnRoundDark}" Margin="0,0,8,0" Click="WelcomeFaqBtn_Click" />
            <Button Name="WelcomeGotItBtn" Content="Got It, Let's Go" Width="120" Height="32"
                    Style="{StaticResource btnRoundDark}" Click="WelcomeGotItBtn_Click" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

  </Grid>
</Window>
