<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="NTE_Fishing_Bot.SettingsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:NTE_Fishing_Bot" x:Name="SettingsWindow1" Title="Settings" Height="720" Width="800" Closed="SettingsWindow1_Closed">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources/StylingDictionary.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="5">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="256" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- LEFT: Button Setup -->
    <GroupBox Name="ButtonsGBox" Header="Button Setup" Grid.Column="0" Margin="0,3,4,0" VerticalAlignment="Top">
      <StackPanel Width="256">
        <StackPanel Height="65" Orientation="Horizontal">
          <Button Name="MoveLeftBtn" Height="50" Width="85" Style="{StaticResource btnRoundDark}" BorderThickness="2,2,2,2" Margin="16,0,0,0" Click="MoveLeftBtn_Click">
            <TextBlock Name="MoveLeftLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="24" Text="A" />
          </Button>
          <Label Name="MoveLeftDescription" Content="Move Left Hotkey&#xD;&#xA;(Default: A)&#xD;&#xA;" VerticalAlignment="Center" Width="132" VerticalContentAlignment="Center" Height="42" HorizontalAlignment="Left" Margin="16,0,0,0" />
        </StackPanel>
        <StackPanel Height="65" Orientation="Horizontal">
          <Button Name="MoveRightBtn" Height="50" Width="85" Style="{StaticResource btnRoundDark}" BorderThickness="2,2,2,2" Margin="16,0,0,0" Click="MoveRightBtn_Click">
            <TextBlock Name="MoveRightLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="24" Text="D" />
          </Button>
          <Label Name="MoveRightDescription" Content="Move Right Hotkey&#xD;&#xA;(Default: D)&#xD;&#xA;" VerticalAlignment="Center" Width="132" VerticalContentAlignment="Center" Height="42" HorizontalAlignment="Left" Margin="16,0,0,0" />
        </StackPanel>
        <StackPanel Height="65" Orientation="Horizontal">
          <Button Name="ReelInBtn" Height="50" Width="85" Style="{StaticResource btnRoundDark}" BorderThickness="2,2,2,2" Margin="16,0,0,0" Click="ReelInBtn_Click">
            <TextBlock Name="ReelInLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="24" Text="F" />
          </Button>
          <Label Name="ReelInDescription" Content="Reel-In Hotkey&#xD;&#xA;(Default: F)&#xD;&#xA;" VerticalAlignment="Center" Width="132" VerticalContentAlignment="Center" Height="42" HorizontalAlignment="Left" Margin="16,0,0,0" />
        </StackPanel>
        <StackPanel Height="65" Orientation="Horizontal">
          <Button Name="DismissBtn" Height="50" Width="85" Style="{StaticResource btnRoundDark}" BorderThickness="2,2,2,2" Margin="16,0,0,0" Click="DismissBtn_Click">
            <TextBlock Name="DismissLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="24" Text="ESC" />
          </Button>
          <Label Name="DismissDescription" Content="Dismiss Hotkey&#xD;&#xA;(Default: ESC)&#xD;&#xA;" VerticalAlignment="Center" Width="132" VerticalContentAlignment="Center" Height="42" HorizontalAlignment="Left" Margin="16,0,0,0" />
        </StackPanel>
      </StackPanel>
    </GroupBox>

    <!-- RIGHT: Delays, Discord, Reset -->
    <Grid Grid.Column="1" Margin="4,3,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Delay Customization -->
      <GroupBox Name="DelayGBox" Header="Delay Customization" Grid.Row="0" Margin="0,0,0,5">
        <StackPanel>
          <StackPanel Name="DelayRow1" Height="30" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Name="LabelRow1" Content="Start" FontSize="16" Margin="1,0,15,0" />
          </StackPanel>
          <StackPanel Name="DelayRow2" Height="40" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Name="ArrowRow2" Source="/img/arrow_night.png" Margin="1,0,15,0" />
          </StackPanel>
          <StackPanel Name="DelayRow3" Height="60" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Name="DelayRestartGBox" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,25,0">
              <StackPanel Name="DelayRow3Label" Height="30" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Label Name="DelayRestartLabel" Content="Restart Delay" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                <Image Name="InfoRow3Column1" Source="/img/info_night.png" Height="15" Margin="-3,0,0,0" ToolTipService.InitialShowDelay="400">
                  <FrameworkElement.ToolTip>
                    <ToolTip Name="DelayRestartTooltip">
                      <StackPanel Width="430">
                        <StackPanel Name="DelayRestartTooltipHeader" Orientation="Horizontal" Background="#FFD2B48C" Width="430">
                          <Label Name="DelayRestartTooltipHeaderValue" Content="Delay before dismissing the Capture screen" Margin="10 5" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Name="DelayRestartTooltipDescription" Text="Delay before the tool restarts the fishing process again after pressing the Dismiss Hotkey" FontSize="14" TextWrapping="WrapWithOverflow" />
                        <Line Name="DelayRestartTooltipLine" Stroke="#FF808080" StrokeThickness="2" X2="200" Margin="0,3,0,3" />
                        <TextBlock Name="DelayRestartTooltipDefault" Text="Value in ms. Default Value: 2000" FontWeight="ExtraBold" />
                      </StackPanel>
                    </ToolTip>
                  </FrameworkElement.ToolTip>
                </Image>
              </StackPanel>
              <TextBox Name="RestartDelayTextBox" Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" TextAlignment="Center" TextChanged="DelayTextBox_TextChanged" PreviewTextInput="PositiveNumbersOnlyValidation" />
            </StackPanel>
            <Image Name="ArrowRow3Column1" Source="/img/arrow_night.png" Height="30" Margin="1,0,25,0" />
            <TextBlock Name="StaminaBarAppearsLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Margin="1,0,1,0">Stamina<LineBreak />Bar<LineBreak />Appears</TextBlock>
            <Image Name="ArrowRow3Column2" Source="/img/arrow_night.png" Height="30" Margin="25,0,25,0" />
            <StackPanel Name="DelayLagCompensationGBox" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,1,0">
              <StackPanel Name="DelayRow3Column2Label" Height="30" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Label Name="DelayLagCompensationLabel" Content="Lag Comp Delay" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                <Image Name="InfoRow3Column2" Source="/img/info_night.png" Height="15" Margin="-3,0,0,0" ToolTipService.InitialShowDelay="400">
                  <FrameworkElement.ToolTip>
                    <ToolTip Name="DelayLagCompensationTooltip">
                      <StackPanel Width="430">
                        <StackPanel Name="DelayLagCompensationTooltipHeader" Orientation="Horizontal" Background="#FFD2B48C" Width="430">
                          <Label Name="DelayLagCompensationTooltipHeaderValue" Content="Lag Compensation Delay at start of fishing" Margin="10 5" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Name="DelayLagCompensationTooltipDescription" Text="Delay to prevent the tool by reeling in immediatly after starting. After starting to fish, there is a delay/lag associated before the fish stamina is filled. This is the delay to compensate for that." FontSize="14" TextWrapping="WrapWithOverflow" />
                        <Line Name="DelayLagCompensationTooltipLine" Stroke="#FF808080" StrokeThickness="2" X2="200" Margin="0,3,0,3" />
                        <TextBlock Name="DelayLagCompensationTooltipDefault" Text="Value in ms. Default Value: 5000" FontWeight="ExtraBold" />
                      </StackPanel>
                    </ToolTip>
                  </FrameworkElement.ToolTip>
                </Image>
              </StackPanel>
              <TextBox Name="LagCompensationDelayTextBox" Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" TextAlignment="Center" TextChanged="DelayTextBox_TextChanged" PreviewTextInput="PositiveNumbersOnlyValidation" />
            </StackPanel>
          </StackPanel>
          <StackPanel Name="DelayRow4" Height="40" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Name="ArrowRow4Column1" Source="/img/arrow_night.png" Margin="5,0,325,0" />
            <Image Name="ArrowRow4Column2" Source="/img/arrow_night.png" Margin="25,0,10,0" />
          </StackPanel>
          <StackPanel Name="DelayRow5" Height="60" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
            <TextBlock Name="DismissLabel2" TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Margin="1,0,1,0" HorizontalAlignment="Center" VerticalAlignment="Center">Dismiss<LineBreak />Screen</TextBlock>
            <StackPanel Name="GPUGroup" Height="60" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="35,0,1,0">
              <Label Name="GPULabel" Content="GPU Selection" HorizontalAlignment="Center" FontSize="12" />
              <ComboBox Name="GPUList" Width="250" SelectionChanged="GPUList_SelectionChanged" />
            </StackPanel>
            <TextBlock Name="FishStamDepleteLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Margin="35,0,1,0" HorizontalAlignment="Center" VerticalAlignment="Center">Fish<LineBreak />Stamina<LineBreak />Depleted</TextBlock>
          </StackPanel>
          <StackPanel Name="DelayRow6" Height="40" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Name="ArrowRow6Column1" Source="/img/arrow_night.png" Margin="5,0,325,0" />
            <Image Name="ArrowRow6Column2" Source="/img/arrow_night.png" Margin="25,0,10,0" />
          </StackPanel>
          <StackPanel Name="DelayRow7" Height="90" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-15,0,0">
            <StackPanel Name="DelayDimissGBox" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="7,0,23,0">
              <StackPanel Name="DelayRow7Label" Height="30" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Label Name="DelayDimissLabel" Content="Dimiss Delay" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                <Image Name="InfoRow7Column1" Source="/img/info_night.png" Height="15" Margin="-3,0,0,0" ToolTipService.InitialShowDelay="400">
                  <FrameworkElement.ToolTip>
                    <ToolTip Name="DelayDimissTooltip">
                      <StackPanel Width="430">
                        <StackPanel Name="DelayDimissTooltipHeader" Orientation="Horizontal" Background="#FFD2B48C" Width="430">
                          <Label Name="DelayDimissTooltipHeaderValue" Content="Delay before dismissing the Capture screen" Margin="10 5" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Name="DelayDimissTooltipDescription" Text="Delay before the tool presses the dismiss hotkey after capturing the fish. This is needed when you don't have all the alphas caught. If you have all the alphas caught and want to speed up the fishing loop a bit, you can change this down to 2000" FontSize="14" TextWrapping="WrapWithOverflow" />
                        <Line Name="DelayDimissTooltipLine" Stroke="#FF808080" StrokeThickness="2" X2="200" Margin="0,3,0,3" />
                        <TextBlock Name="DelayDimissTooltipDefault" Text="Value in ms. Default Value: 4000" FontWeight="ExtraBold" />
                      </StackPanel>
                    </ToolTip>
                  </FrameworkElement.ToolTip>
                </Image>
              </StackPanel>
              <TextBox Name="DimissDelayTextBox" Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" TextAlignment="Center" TextChanged="DelayTextBox_TextChanged" PreviewTextInput="PositiveNumbersOnlyValidation" />
            </StackPanel>
            <Image Name="ArrowRow7Column1" Source="/img/arrow_night.png" Height="30" Margin="1,0,25,0" />
            <TextBlock Name="ReelInButtonLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Margin="1,15,1,0">Reel-In<LineBreak />Button<LineBreak />Pressed</TextBlock>
            <Image Name="ArrowRow7Column2" Source="/img/arrow_night.png" Height="30" Margin="25,0,25,0" />
            <StackPanel Name="DelayFishCaptureGBox" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,1,0">
              <StackPanel Name="DelayRow7Column2Label" Height="30" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Label Name="DelayFishCaptureLabel" Content="Fish Capture Delay" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                <Image Name="InfoRow7Column2" Source="/img/info_night.png" Height="15" Margin="-3,0,0,0" ToolTipService.InitialShowDelay="400">
                  <FrameworkElement.ToolTip>
                    <ToolTip Name="DelayFishCaptureTooltip">
                      <StackPanel Width="430">
                        <StackPanel Name="DelayFishCaptureTooltipHeader" Orientation="Horizontal" Background="#FFD2B48C" Width="430">
                          <TextBlock Name="DelayFishCaptureTooltipHeaderValue" TextWrapping="Wrap" Margin="10 5" FontSize="20" FontWeight="Bold">Delay before capturing fish after detected<LineBreak />fish stamina has been depleted</TextBlock>
                        </StackPanel>
                        <TextBlock Name="DelayFishCaptureTooltipDescription" Text="Delay before the tool presses the reel-in hotkey. When the tool detects that the fish stamina is depleted, it will wait for this delay before capturing the fish. If you notice that the tool sometimes pre-emptively catches a fish on higher stamina fish or alphas, then increasing this delay will force the tool to wait longer before capturing the fish." FontSize="14" TextWrapping="WrapWithOverflow" />
                        <Line Name="DelayFishCaptureTooltipLine" Stroke="#FF808080" StrokeThickness="2" X2="200" Margin="0,3,0,3" />
                        <TextBlock Name="DelayFishCaptureTooltipDefault" Text="Value in ms. Default Value: 3000" FontWeight="ExtraBold" />
                      </StackPanel>
                    </ToolTip>
                  </FrameworkElement.ToolTip>
                </Image>
              </StackPanel>
              <TextBox Name="FishCaptureDelayTextBox" Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" TextAlignment="Center" TextChanged="DelayTextBox_TextChanged" PreviewTextInput="PositiveNumbersOnlyValidation" />
            </StackPanel>
          </StackPanel>
          <StackPanel Name="PostCatchSectionRow" Height="30" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0">
            <Label Name="PostCatchSectionLabel" Content="Post-Catch Sequence Delays (ms)" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" />
          </StackPanel>
          <StackPanel Name="PostCatchDelayRow" Height="60" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,20,0">
              <Label Name="PostCatchDelayLabel" Content="After Catch" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
              <TextBox Name="PostCatchDelayTextBox" Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" TextAlignment="Center" TextChanged="DelayTextBox_TextChanged" PreviewTextInput="PositiveNumbersOnlyValidation" />
            </StackPanel>
            <StackPanel Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,1,0">
              <Label Name="AfterClickDelayLabel" Content="After Esc" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
              <TextBox Name="AfterClickDelayTextBox" Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" TextAlignment="Center" TextChanged="DelayTextBox_TextChanged" PreviewTextInput="PositiveNumbersOnlyValidation" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </GroupBox>

      <!-- Discord Integration -->
      <GroupBox Name="DiscordGBox" Header="Discord Integration (WIP)" Grid.Row="1" Margin="0,0,0,5" BorderBrush="{x:Null}">
        <StackPanel>
          <StackPanel Height="30" Orientation="Horizontal" HorizontalAlignment="Left">
            <Label Name="DiscordUserIdLabel" Content="Discord User Id" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="12" />
            <Image Name="DiscordInfoRow1" Source="/img/info_night.png" Height="15" Margin="-3,0,0,0" ToolTipService.InitialShowDelay="400">
              <FrameworkElement.ToolTip>
                <ToolTip Name="DiscordUserIdTooltip">
                  <StackPanel Width="360">
                    <StackPanel Name="DiscordUserIdTooltipHeader" Orientation="Horizontal" Background="#FFD2B48C" Width="360">
                      <TextBlock Name="DiscordUserIdTooltipHeaderValue" TextWrapping="Wrap" Margin="10 5" FontSize="20" FontWeight="Bold">Discord User Id</TextBlock>
                    </StackPanel>
                    <TextBlock Name="DiscordUserIdTooltipDescription" Text="The User id that you want to be mentioned when you run out of bait. See Discord Notification Section in Github Page on how to get yours" FontSize="14" TextWrapping="WrapWithOverflow" />
                    <Line Name="DiscordUserIdTooltipLine" Stroke="#FF808080" StrokeThickness="2" X2="200" Margin="0,3,0,3" />
                    <TextBlock Name="DiscordUserIdTooltipDefault" Text="Example: 123456789012345678 (Usually 18 characters long)" FontWeight="ExtraBold" />
                  </StackPanel>
                </ToolTip>
              </FrameworkElement.ToolTip>
            </Image>
          </StackPanel>
          <TextBox Name="DiscordUserIdTextBox" Width="200" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="16" TextAlignment="Center" Text="NOT_EMPTY" TextChanged="DelayTextBox_TextChanged" PreviewTextInput="PositiveNumbersOnlyValidation" />
          <StackPanel Height="30" Orientation="Horizontal" HorizontalAlignment="Left">
            <Label Name="DiscordWebHookLabel" Content="Discord Webhook URL" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="12" />
            <Image Name="DiscordInfoRow2" Source="/img/info_night.png" Height="15" Margin="-3,0,0,0">
              <FrameworkElement.ToolTip>
                <ToolTip Name="DiscordWebHookTooltip">
                  <StackPanel Width="330">
                    <StackPanel Name="DiscordWebHookTooltipHeader" Orientation="Horizontal" Background="#FFD2B48C" Width="330">
                      <TextBlock Name="DiscordWebHookTooltipHeaderValue" TextWrapping="Wrap" Margin="10 5" FontSize="20" FontWeight="Bold">Discord Webhook URL</TextBlock>
                    </StackPanel>
                    <TextBlock Name="DiscordWebHookTooltipDescription" Text="The Discord Webhook URL that this tool will send a notification to when it runs out of bait. See Discord Notification Section in Github Page on how to setup yours" FontSize="14" TextWrapping="WrapWithOverflow" />
                    <Line Name="DiscordWebHookTooltipLine" Stroke="#FF808080" StrokeThickness="2" X2="200" Margin="0,3,0,3" />
                    <TextBlock Name="DiscordWebHookTooltipDefault" Text="Example: https://discordapp.com/api/webhooks/xxxx" FontWeight="ExtraBold" />
                  </StackPanel>
                </ToolTip>
              </FrameworkElement.ToolTip>
            </Image>
          </StackPanel>
          <TextBox Name="DiscordWebHookTextBox" HorizontalAlignment="Stretch" VerticalAlignment="Center" FontSize="16" TextAlignment="Left" TextWrapping="Wrap" AcceptsReturn="True" Height="45" Text="NOT_EMPTY" TextChanged="DelayTextBox_TextChanged" />
        </StackPanel>
      </GroupBox>

      <!-- Reset Button -->
      <Button Name="ResetBtn" Grid.Row="2" HorizontalAlignment="Right" Height="50" Width="150" Style="{StaticResource btnRoundDark}" BorderThickness="2,2,2,2" Margin="0,0,0,5" Click="ResetBtn_Click">
        <TextBlock Name="ResetLabel" TextWrapping="Wrap" TextAlignment="Center" FontSize="16" Text="Reset All To Default" />
      </Button>
    </Grid>
  </Grid>
</Window>
